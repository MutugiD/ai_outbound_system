# AI Outbound Operating System — Environment Variables
# Copy to .env and fill in your values

# ── Database ──
DATABASE_URL=postgresql+asyncpg://outbound:outbound@localhost:5432/outbound_os
DATABASE_URL_SYNC=postgresql://outbound:outbound@localhost:5432/outbound_os

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Auth ──
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ENCRYPTION_KEY=change-this-to-a-random-high-entropy-string
ENCRYPTION_KEY_ID=v1
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── LLM ──
LLM_PROVIDER=ollama  # ollama, openai, or anthropic
LLM_BASE_URL=http://localhost:11434/v1  # Ollama default; https://api.openai.com/v1 for OpenAI
LLM_MODEL=glm-5.1:cloud  # Default model for Ollama
OPENAI_API_KEY=  # Required only if LLM_PROVIDER=openai
ANTHROPIC_API_KEY=  # Required only if LLM_PROVIDER=anthropic

# ── Enrichment APIs ──
APOLLO_API_KEY=your-apollo-key
PDL_API_KEY=your-people-data-labs-key
BUILTWITH_API_KEY=your-builtwith-key

# ── Email ──
BREVO_API_KEY=your-brevo-api-key
BREVO_WEBHOOK_BEARER_TOKEN=your-brevo-webhook-bearer-token
SENDGRID_API_KEY=your-sendgrid-key
RESEND_API_KEY=your-resend-key
OUTREACH_FROM_EMAIL=outreach@yourdomain.com
OUTREACH_FROM_NAME=AI Outbound OS
OUTREACH_REPLY_TO=reply@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_your_resend_signing_secret
SMARTLEAD_API_KEY=your-smartlead-key

# ── Search / Scraping ──
SERPAPI_KEY=your-serpapi-key
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=ai-outbound-os/1.0

# ── Website Audit ──
PAGESPEED_API_KEY=your-pagespeed-key

# ── SMS ──
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Object Storage (MinIO local — no AWS needed) ──
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=outbound-os

# ── App ──
DEBUG=true
APP_VERSION=
GIT_SHA=
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
